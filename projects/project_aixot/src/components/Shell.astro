---
import { sections } from '../data/dummy';

const total = String(sections.length).padStart(2, '0');
---

<header class="chrome-header">
  <div class="chrome-brand">Aix-en-Provence</div>
  <nav class="chrome-nav" aria-label="Sections">
    {
      sections.map((section, i) => (
        <button class:list={['nav-link', { active: i === 0 }]} data-nav-index={i}>
          {section.label}
        </button>
      ))
    }
  </nav>
</header>

<footer class="chrome-footer">
  <div class="chrome-progress"><span class="cur" data-progress-current>01</span> &nbsp;/&nbsp; {total}</div>
  <div class="chrome-hint" aria-hidden="true">← →</div>
</footer>
