---
import MapIsland from '../islands/MapIsland.tsx';
import { flights } from '../../data/dummy';
---

<section class="slide" id="slide-location" data-section="location">
  <div class="slide-inner slide-inner--flush location">
    <div class="location-stage">
      <div class="map-wrap">
        <MapIsland client:only="react" />
      </div>

      <aside class="flights-card">
        <div class="flights-head">
          <svg class="flights-plane" viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5z"
            ></path>
          </svg>
          <p class="label flights-subtitle">{flights.subtitle}</p>
        </div>

        <ul class="flights-list">
          {flights.destinations.map((city) => <li class="flights-dest">{city}</li>)}
        </ul>

        <p class="flights-foot">{flights.distanceNote}</p>
      </aside>
    </div>
  </div>
</section>

<style>
  .location {
    height: 100%;
  }
  .location-stage {
    /* ~900px square map, shrinking to leave room for the card on smaller screens. */
    --side: min(820px, calc(100vh - 120px), calc(94vw - 360px));
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 36px;
  }
  .map-wrap {
    position: relative;
    width: var(--side);
    height: var(--side);
    border: 2px solid #556b2f;
    box-sizing: border-box;
  }

  /* ---- Side card ---- */
  .flights-card {
    width: 288px;
    height: var(--side);
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--rule);
    border-top: 2px solid var(--accent);
    padding: 26px 26px 22px;
  }
  .flights-head {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .flights-plane {
    width: 18px;
    height: 18px;
    fill: var(--accent);
    flex: none;
    transform: rotate(45deg);
  }
  .flights-subtitle {
    color: var(--ink);
    letter-spacing: 2px;
  }

  .flights-list {
    list-style: none;
    margin: 22px 0 18px;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }
  .flights-dest {
    font-family: var(--serif);
    font-size: 17px;
    color: var(--ink);
    padding: 7px 0;
    border-bottom: 1px solid var(--rule);
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0.75;
    transition: opacity 160ms ease, padding-left 160ms ease;
    cursor: default;
  }
  .flights-dest::before {
    content: '';
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    flex: none;
  }
  .flights-dest:hover {
    opacity: 1;
    padding-left: 4px;
  }

  .flights-foot {
    font-family: var(--serif);
    font-size: 12px;
    line-height: 1.5;
    color: var(--ink-2);
    padding-top: 16px;
    border-top: 1px solid var(--accent);
  }
</style>
