---
import { whyAix, whyPoints } from '../../data/dummy';

const base = import.meta.env.BASE_URL;
---

<section class="slide" id="slide-why" data-section="why">
  <div class="slide-inner">
    <div class="why-grid">
      <div class="why-left">
        <img
          class="why-cezanne"
          src={`${base}cezanne-square.jpg`}
          width="84"
          height="84"
          loading="eager"
          alt="Cézanne, Mont Sainte-Victoire — the mountain overlooking Aix-en-Provence"
        />
        <p class="label">{whyAix.eyebrow}</p>
        <h2 class="serif-heading why-heading">{whyAix.heading}</h2>
        <p class="serif-body why-body">{whyAix.body}</p>
        <hr class="rule why-rule" />
      </div>

      <div class="why-right">
        <ul class="why-list">
          {
            whyPoints.map((point) => (
              <li class="why-item">
                <div class="why-item-head">
                  <span class="why-mark" aria-hidden="true">⚜︎</span>
                  <span class="why-title">{point.title}</span>
                </div>
                <div class="why-detail">
                  <p>{point.detail}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .why-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
  }
  .why-cezanne {
    display: block;
    width: 84px;
    height: 84px;
    object-fit: cover;
    opacity: 0.8;
    margin-bottom: 26px;
  }
  .why-heading {
    font-size: 38px;
    margin-bottom: 24px;
  }
  .why-body {
    margin-bottom: 28px;
    max-width: 30em;
  }
  .why-rule {
    max-width: 30em;
  }
  .why-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .why-item {
    border-bottom: 1px solid var(--rule);
    padding: 15px 0;
  }
  .why-item:first-child {
    border-top: 1px solid var(--rule);
  }
  .why-item-head {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .why-mark {
    width: 30px;
    flex: none;
    text-align: center;
    color: var(--ink-3);
    font-size: 30px;
    line-height: 1;
    transition: color 220ms ease;
  }
  .why-item:hover .why-mark {
    color: var(--accent);
  }
  .why-title {
    font-family: var(--serif);
    font-size: 16px;
    color: var(--ink);
    transition: color 200ms ease;
  }
  .why-detail {
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition: max-height 300ms ease, opacity 300ms ease;
  }
  .why-detail p {
    font-size: 14px;
    color: var(--ink-2);
    line-height: 1.6;
    margin: 9px 0 0;
    padding-left: 46px;
  }
  .why-item:hover .why-detail {
    max-height: 90px;
    opacity: 1;
  }
</style>
