---
import CostIsland from '../islands/CostIsland.tsx';
---

<section class="slide" id="slide-costs" data-section="costs">
  <div class="slide-inner costs">
    <div class="cost-head">
      <p class="label">Financial Overview</p>
      <h2 class="serif-heading cost-heading">The case for consolidation</h2>
      <p class="cost-subline">
        Four homes today become one in Aix. Adjust the figures below to test the saving.
      </p>
    </div>
    <CostIsland client:load />
  </div>
</section>

<style>
  .costs {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }
  .cost-head {
    margin-bottom: 36px;
  }
  .cost-heading {
    font-size: 36px;
    margin: 10px 0 8px;
  }
  .cost-subline {
    font-family: var(--serif);
    font-size: 15px;
    color: var(--ink-2);
  }
</style>
