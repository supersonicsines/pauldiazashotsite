---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
	title: string;
	description?: string;
	lang?: 'en' | 'ru';
	alternates?: boolean;
}

const { title, description = 'Paul Diaz Ashot', lang = 'en', alternates = false } = Astro.props;
const SITE_URL = 'https://pauldiazashot.com';
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<title>{title}</title>
		{alternates && <link rel="alternate" hreflang="en" href={`${SITE_URL}/`} />}
		{alternates && <link rel="alternate" hreflang="ru" href={`${SITE_URL}/ru/`} />}
		{alternates && <link rel="alternate" hreflang="x-default" href={`${SITE_URL}/`} />}
		<Analytics />
	</head>
	<body>
		<!-- Loading overlay with cycling symbols + watermark transition.
		     The SVG fills the viewport and zooms by increasing text size, avoiding
		     Safari's tendency to rasterize and then upscale transformed SVG layers. -->
		<div class="overlay" id="overlay">
			<svg
				class="loader"
				id="loader"
				aria-hidden="true"
				focusable="false"
			>
				<text
					class="loader-glyph"
					id="loader-glyph"
					x="50%"
					y="50%"
					text-anchor="middle"
					dominant-baseline="central"
				>&</text>
			</svg>
		</div>

		<!-- Page content -->
		<slot />
	</body>
</html>

<style>
	body {
		background: var(--color-paper);
		margin: 0;
		min-height: 100vh;
		overflow-x: hidden;
	}

	.overlay {
		position: fixed;
		inset: 0;
		background: var(--color-paper);
		display: flex;
		align-items: center;
		justify-content: center;
		/* Boot screen covers everything, including the taskbar (z 2000). */
		z-index: 3000;
		cursor: pointer;
		overflow: hidden;
	}

	.overlay.zooming {
		pointer-events: none;
	}

	.overlay.watermarked {
		z-index: 0;
		background: transparent;
		pointer-events: none;
	}

	.loader {
		--loader-size: 72px;
		--watermark-size: 5760px;
		width: 100vw;
		height: 100vh;
		display: block;
		overflow: visible;
	}

	.loader-glyph {
		font-family: var(--font-serif);
		font-size: var(--loader-size);
		font-weight: 700;
		fill: var(--color-bistre);
		text-rendering: geometricPrecision;
	}

	.loader.zooming .loader-glyph {
		animation: glyphZoom 1200ms cubic-bezier(0.65, 0, 0.35, 1) forwards;
	}

	.loader.watermarked {
		opacity: 0.05;
	}

	/* Warm boot (taskbar language switch): land directly on the watermark
	   without replaying the zoom, preserving the one-workstation illusion. */
	.loader.instant .loader-glyph {
		font-size: var(--watermark-size);
		animation: none;
	}

	@keyframes glyphZoom {
		0% {
			font-size: var(--loader-size);
		}
		100% {
			font-size: var(--watermark-size);
		}
	}

	@media (max-width: 768px) {
		.loader {
			--loader-size: 56px;
			--watermark-size: 4480px;
		}
	}
</style>

<script>
	import { readPdosState, updatePdosState, consumeWarmBoot } from '../scripts/pdosState';

	const baseSymbols = ['&', '/', '*', '?', '·', '#', '§', '†', '‡', '¶'];
	const loader = document.getElementById('loader');
	const glyph = document.getElementById('loader-glyph');
	const overlay = document.getElementById('overlay');
	const warmBoot = consumeWarmBoot();

	let queue: string[] = [];
	let transitioned = false;
	let interval: number;
	let timeout: number;

	function shuffle(array: string[]) {
		const arr = [...array];
		for (let i = arr.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[arr[i], arr[j]] = [arr[j], arr[i]];
		}
		return arr;
	}

	function getNextSymbol() {
		if (queue.length === 0) {
			queue = shuffle(baseSymbols);
		}
		return queue.shift()!;
	}

	function tick() {
		if (glyph) glyph.textContent = getNextSymbol();
	}

	function triggerTransition() {
		if (transitioned || !loader || !overlay) return;
		transitioned = true;
		clearInterval(interval);
		clearTimeout(timeout);

		loader.classList.add('zooming');
		overlay.classList.add('zooming');

		setTimeout(() => {
			overlay.classList.add('watermarked');
			loader.classList.add('watermarked');
		}, 1200);
	}

	if (loader && glyph && overlay) {
		if (warmBoot) {
			transitioned = true;
			loader.classList.add('instant', 'watermarked');
			overlay.classList.add('watermarked');
		} else {
			tick();
			interval = window.setInterval(tick, 250);
			timeout = window.setTimeout(triggerTransition, 3000);
			overlay.addEventListener('click', triggerTransition);
		}
	}

	// --- Session persistence: collapsed sections + expanded sidenotes ------
	// Ids match across language pages, so restoring here is what makes the
	// taskbar switch feel like one workstation. WindowManager owns windows.

	const persisted = readPdosState();

	for (const [id, open] of Object.entries(persisted.collapsibles ?? {})) {
		const section = document.getElementById(id);
		if (!section || !section.classList.contains('collapsible')) continue;
		section.setAttribute('data-open', String(Boolean(open)));
		section.querySelector('.toggle-btn')?.setAttribute('aria-expanded', String(Boolean(open)));
	}

	for (const [id, checked] of Object.entries(persisted.sidenotes ?? {})) {
		const box = document.getElementById(`sn-${id}`);
		if (box instanceof HTMLInputElement) box.checked = Boolean(checked);
	}

	if (warmBoot && typeof persisted.scrollY === 'number') {
		window.scrollTo(0, persisted.scrollY);
	}

	function saveDocumentState() {
		const collapsibles: Record<string, boolean> = {};
		document.querySelectorAll<HTMLElement>('.collapsible[id]').forEach((section) => {
			collapsibles[section.id] = section.getAttribute('data-open') === 'true';
		});
		const sidenotes: Record<string, boolean> = {};
		document.querySelectorAll<HTMLInputElement>('input.sidenote-checkbox[id]').forEach((box) => {
			sidenotes[box.id.replace(/^sn-/, '')] = box.checked;
		});
		updatePdosState((state) => ({ ...state, collapsibles, sidenotes }));
	}

	document.addEventListener('click', (e) => {
		const target = e.target;
		if (target instanceof Element && target.closest('.collapsible .toggle-btn')) {
			// The Collapsible's own handler flips data-open first (it bubbles
			// before this document listener); the microtask is extra safety.
			queueMicrotask(saveDocumentState);
		}
	});

	document.addEventListener('change', (e) => {
		if (e.target instanceof Element && e.target.classList.contains('sidenote-checkbox')) {
			saveDocumentState();
		}
	});

	document.querySelectorAll('.cv li, .cv-content li').forEach((item) => {
		if (item.querySelector(':scope > .list-marker-symbol')) return;

		const marker = document.createElement('span');
		marker.className = 'list-marker-symbol';
		marker.textContent = '*';
		marker.setAttribute('aria-hidden', 'true');
		item.classList.add('has-interactive-marker');
		item.prepend(marker);

		let markerQueue: string[] = [];
		let markerInterval: number | undefined;

		function getNextMarkerSymbol() {
			if (markerQueue.length === 0) {
				markerQueue = shuffle(baseSymbols);
			}
			return markerQueue.shift()!;
		}

		function cycleMarker() {
			marker.textContent = getNextMarkerSymbol();
		}

		function startMarkerCycle() {
			if (markerInterval) return;
			marker.classList.add('is-cycling');
			cycleMarker();
			markerInterval = window.setInterval(cycleMarker, 250);
		}

		function stopMarkerCycle() {
			if (markerInterval) {
				clearInterval(markerInterval);
				markerInterval = undefined;
			}
			marker.classList.remove('is-cycling');
			marker.textContent = '*';
		}

		function isInternalMouseTransition(event: MouseEvent) {
			const relatedTarget = event.relatedTarget;
			return relatedTarget instanceof Node && item.contains(relatedTarget);
		}

		item.addEventListener('pointerenter', startMarkerCycle);
		item.addEventListener('pointerleave', stopMarkerCycle);
		item.addEventListener('mouseenter', startMarkerCycle);
		item.addEventListener('mouseleave', stopMarkerCycle);
		item.addEventListener('mouseover', (event) => {
			if (!isInternalMouseTransition(event)) startMarkerCycle();
		});
		item.addEventListener('mouseout', (event) => {
			if (!isInternalMouseTransition(event)) stopMarkerCycle();
		});
	});
</script>
