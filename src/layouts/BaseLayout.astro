---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Paul Diaz Ashot' } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content={description} />
		<title>{title}</title>
		<Analytics />
	</head>
	<body>
		<!-- Loading overlay with cycling symbols + watermark transition.
		     The SVG fills the viewport and zooms by increasing text size, avoiding
		     Safari's tendency to rasterize and then upscale transformed SVG layers. -->
		<div class="overlay" id="overlay">
			<svg
				class="loader"
				id="loader"
				aria-hidden="true"
				focusable="false"
			>
				<text
					class="loader-glyph"
					id="loader-glyph"
					x="50%"
					y="50%"
					text-anchor="middle"
					dominant-baseline="central"
				>&</text>
			</svg>
		</div>

		<!-- Page content -->
		<slot />
	</body>
</html>

<style>
	body {
		background: var(--color-paper);
		margin: 0;
		min-height: 100vh;
		overflow-x: hidden;
	}

	.overlay {
		position: fixed;
		inset: 0;
		background: var(--color-paper);
		display: flex;
		align-items: center;
		justify-content: center;
		z-index: 100;
		cursor: pointer;
		overflow: hidden;
	}

	.overlay.zooming {
		pointer-events: none;
	}

	.overlay.watermarked {
		z-index: 0;
		background: transparent;
		pointer-events: none;
	}

	.loader {
		--loader-size: 72px;
		--watermark-size: 5760px;
		width: 100vw;
		height: 100vh;
		display: block;
		overflow: visible;
	}

	.loader-glyph {
		font-family: var(--font-serif);
		font-size: var(--loader-size);
		font-weight: 700;
		fill: var(--color-bistre);
		text-rendering: geometricPrecision;
	}

	.loader.zooming .loader-glyph {
		animation: glyphZoom 1200ms cubic-bezier(0.65, 0, 0.35, 1) forwards;
	}

	.loader.watermarked {
		opacity: 0.05;
	}

	@keyframes glyphZoom {
		0% {
			font-size: var(--loader-size);
		}
		100% {
			font-size: var(--watermark-size);
		}
	}

	@media (max-width: 768px) {
		.loader {
			--loader-size: 56px;
			--watermark-size: 4480px;
		}
	}
</style>

<script>
	const baseSymbols = ['&', '/', '*', '?', '·', '#', '§', '†', '‡', '¶'];
	const loader = document.getElementById('loader');
	const glyph = document.getElementById('loader-glyph');
	const overlay = document.getElementById('overlay');

	let queue: string[] = [];
	let transitioned = false;
	let interval: number;
	let timeout: number;

	function shuffle(array: string[]) {
		const arr = [...array];
		for (let i = arr.length - 1; i > 0; i--) {
			const j = Math.floor(Math.random() * (i + 1));
			[arr[i], arr[j]] = [arr[j], arr[i]];
		}
		return arr;
	}

	function getNextSymbol() {
		if (queue.length === 0) {
			queue = shuffle(baseSymbols);
		}
		return queue.shift()!;
	}

	function tick() {
		if (glyph) glyph.textContent = getNextSymbol();
	}

	function triggerTransition() {
		if (transitioned || !loader || !overlay) return;
		transitioned = true;
		clearInterval(interval);
		clearTimeout(timeout);

		loader.classList.add('zooming');
		overlay.classList.add('zooming');

		setTimeout(() => {
			overlay.classList.add('watermarked');
			loader.classList.add('watermarked');
		}, 1200);
	}

	if (loader && glyph && overlay) {
		tick();
		interval = window.setInterval(tick, 250);
		timeout = window.setTimeout(triggerTransition, 3000);
		overlay.addEventListener('click', triggerTransition);
	}
</script>
