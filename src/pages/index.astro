<style>
	.cv {
		max-width: 680px;
		margin: 0 auto;
		padding: 48px 24px;
		position: relative;
		z-index: 1;
		counter-reset: sidenote;
	}

	.cv-header,
	.cv-body,
	.cv-footer {
		max-width: 680px;
	}

	.cv-header {
		text-align: center;
		padding-bottom: 14px;
		border-bottom: 0.5px solid var(--color-rule);
		margin-bottom: 12px;
	}

	.cv-header h1 {
		margin: 0 0 8px 0;
		font-family: var(--font-serif);
		font-size: 32px;
		font-weight: 400;
		letter-spacing: 1.5px;
	}

	.locations {
		font-size: 15px;
		color: var(--color-ink);
		margin-bottom: 6px;
		letter-spacing: 0.5px;
	}

	.contact {
		font-family: var(--font-sans);
		font-size: 12px;
		color: var(--color-muted);
		margin-bottom: 4px;
	}

	.contact a {
		color: var(--color-ink);
	}

	.role {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin: 12px 0 4px 0;
		flex-wrap: wrap;
		gap: 4px;
	}

	.role-trigger {
		all: unset;
		cursor: pointer;
		font-size: 15px;
		color: var(--color-ink);
		text-decoration: underline;
		text-decoration-color: var(--color-rule);
		text-underline-offset: 3px;
		text-decoration-thickness: 1px;
		transition: text-decoration-thickness 120ms ease-out;
	}

	.role-trigger:hover,
	.role-trigger:focus-visible {
		text-decoration-thickness: 1.5px;
		text-decoration-color: var(--color-ink);
	}

	.role-trigger:focus-visible {
		outline: 1px solid var(--color-rule);
		outline-offset: 4px;
	}

	.inline-preview-trigger {
		all: unset;
		cursor: pointer;
		color: var(--color-ink);
		text-decoration: underline;
		text-decoration-color: var(--color-rule);
		text-underline-offset: 2px;
		text-decoration-thickness: 1px;
		transition:
			text-decoration-color 120ms ease-out,
			text-decoration-thickness 120ms ease-out;
	}

	.inline-preview-trigger:hover,
	.inline-preview-trigger:focus-visible {
		text-decoration-color: var(--color-ink);
		text-decoration-thickness: 1.5px;
	}

	.inline-preview-trigger:focus-visible {
		outline: 1px solid var(--color-rule);
		outline-offset: 3px;
	}

	.role .dates {
		font-family: var(--font-sans);
		font-size: 12px;
		color: var(--color-muted);
		font-style: italic;
		white-space: nowrap;
	}

	.cv :global(p),
	.cv :global(li) {
		font-size: 15px;
		line-height: 1.5;
		margin: 0 0 6px 0;
	}

	.cv :global(ul) {
		margin: 4px 0 10px 0;
		padding-left: 16px;
		list-style: none;
	}

	.cv :global(li) {
		position: relative;
		padding-left: 14px;
		margin-bottom: 6px;
	}

	.cv :global(li::before) {
		content: "–";
		position: absolute;
		left: 0;
		color: var(--color-ink);
	}

	.cv :global(a) {
		color: var(--color-ink);
		text-decoration: underline;
		text-decoration-color: var(--color-rule);
		text-underline-offset: 2px;
	}

	.cv :global(em) {
		font-style: italic;
	}

	.cv :global(b) {
		font-weight: 700;
	}

	.external-preview {
		position: relative;
		width: 100%;
		height: 100%;
		min-height: 0;
		overflow: hidden;
		background:
			linear-gradient(135deg, rgba(251, 250, 247, 0.08), rgba(61, 43, 31, 0.2)),
			#17110d;
	}

	.external-preview img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
		filter: saturate(0.88) contrast(0.96);
	}

	.external-preview::after {
		content: "";
		position: absolute;
		inset: 0;
		border: 1px solid rgba(251, 250, 247, 0.16);
		pointer-events: none;
	}

	.external-preview .external-preview-arrow {
		position: absolute;
		right: 26px;
		top: 50%;
		transform: translateY(-52%);
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 132px;
		height: 132px;
		color: rgba(251, 250, 247, 0.44);
		font-family: Georgia, 'Times New Roman', serif;
		font-size: 122px;
		font-weight: 400;
		line-height: 1;
		text-decoration: none;
		text-shadow: 0 2px 12px rgba(23, 17, 13, 0.42);
		transition:
			color 140ms ease-out,
			text-shadow 140ms ease-out,
			transform 140ms ease-out;
	}

	.external-preview .external-preview-arrow:hover,
	.external-preview .external-preview-arrow:focus-visible {
		color: rgba(251, 250, 247, 0.92);
		text-shadow: 0 2px 18px rgba(23, 17, 13, 0.74);
		transform: translateY(-52%) translateX(2px);
		outline: none;
	}

	:global(.mobile-window-inline-content) .external-preview {
		height: auto;
		aspect-ratio: 16 / 9;
	}

	:global(.mobile-window-inline-content) .external-preview .external-preview-arrow {
		right: 12px;
		width: 84px;
		height: 84px;
		font-size: 76px;
	}

	.skills {
		line-height: 1.55;
	}

	.cv-footer {
		margin: 32px auto 0 auto;
		padding-top: 16px;
		border-top: 0.5px solid var(--color-rule);
		text-align: center;
		font-family: var(--font-sans);
		font-size: 12px;
		color: var(--color-muted);
	}

	.cv-footer a {
		color: var(--color-ink);
	}

	@media (max-width: 768px) {
		.cv {
			padding: 32px 20px;
		}

		.role {
			flex-direction: column;
			gap: 2px;
		}

		.role .dates {
			font-size: 11px;
		}
	}
</style>
