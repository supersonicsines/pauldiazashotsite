---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Paul Diaz Ashot">
	<main class="essay">
		<header class="essay-header">
			<h1>Paul Diaz Ashot</h1>
			<div class="locations">London, Barcelona, New York</div>
			<div class="contact">
				<a href="mailto:paul.ashot@icloud.com">paul.ashot@icloud.com</a> ·
				(646) 996 5037 ·
				@supersonicsines
			</div>
		</header>

		<p class="lede">
			This page is under construction. The traditional CV is at <a href="/cv">/cv</a>.
		</p>
	</main>
</BaseLayout>

<style>
	.essay {
		max-width: 680px;
		margin: 0 auto;
		padding: 48px 24px;
		position: relative;
		z-index: 1;
	}

	.essay-header {
		text-align: center;
		padding-bottom: 16px;
		border-bottom: 0.5px solid var(--color-rule);
		margin-bottom: 32px;
	}

	.essay-header h1 {
		margin: 0 0 8px 0;
	}

	.locations {
		font-size: 16px;
		color: var(--color-ink);
		margin-bottom: 6px;
		letter-spacing: 0.5px;
	}

	.contact {
		font-family: var(--font-sans);
		font-size: 13px;
		color: var(--color-muted);
	}

	.contact a {
		color: var(--color-ink);
	}

	.lede {
		font-size: 18px;
		line-height: 1.6;
		color: var(--color-ink);
	}

	@media (max-width: 768px) {
		.essay {
			padding: 32px 20px;
		}
	}
</style>
