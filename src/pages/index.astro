<style>
	.cv {
		max-width: 680px;
		margin: 0 auto;
		padding: 48px 24px;
		position: relative;
		z-index: 1;
		counter-reset: sidenote;
	}

	.cv-header,
	.cv-body,
	.cv-footer {
		max-width: 680px;
	}

	@media (min-width: 1280px) {
		.cv {
			max-width: 1000px;
			padding-right: 24px;
		}
		/* On wide screens, content stays 680px left-aligned within the 1000px container.
		   Sidenotes float right into the 320px gutter. */
	}

	.cv-header {
		text-align: center;
		padding-bottom: 14px;
		border-bottom: 0.5px solid var(--color-rule);
		margin-bottom: 12px;
	}

	.cv-header h1 {
		margin: 0 0 8px 0;
		font-family: var(--font-serif);
		font-size: 32px;
		font-weight: 400;
		letter-spacing: 1.5px;
	}

	.locations {
		font-size: 15px;
		color: var(--color-ink);
		margin-bottom: 6px;
		letter-spacing: 0.5px;
	}

	.contact {
		font-family: var(--font-sans);
		font-size: 12px;
		color: var(--color-muted);
		margin-bottom: 4px;
	}

	.contact a {
		color: var(--color-ink);
	}

	.work-auth {
		font-style: italic;
		font-size: 12px;
		color: var(--color-muted);
	}

	.role {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		margin: 10px 0 4px 0;
		flex-wrap: wrap;
		gap: 4px;
	}

	.role .title {
		font-size: 15px;
	}

	.role .dates {
		font-family: var(--font-sans);
		font-size: 12px;
		color: var(--color-muted);
		font-style: italic;
		white-space: nowrap;
	}

	.cv :global(p),
	.cv :global(li) {
		font-size: 15px;
		line-height: 1.5;
		margin: 0 0 6px 0;
	}

	.cv :global(ul) {
		margin: 4px 0 10px 0;
		padding-left: 16px;
		list-style: none;
	}

	.cv :global(li) {
		position: relative;
		padding-left: 14px;
		margin-bottom: 6px;
	}

	.cv :global(li::before) {
		content: "–";
		position: absolute;
		left: 0;
		color: var(--color-ink);
	}

	.cv :global(a) {
		color: var(--color-ink);
		text-decoration: underline;
		text-decoration-color: var(--color-rule);
		text-underline-offset: 2px;
	}

	.cv :global(em) {
		font-style: italic;
	}

	.cv :global(b) {
		font-weight: 700;
	}

	.skills {
		line-height: 1.55;
	}

	.cv-footer {
		max-width: 680px;
		margin: 32px auto 0 auto;
		padding-top: 16px;
		border-top: 0.5px solid var(--color-rule);
		text-align: center;
		font-family: var(--font-sans);
		font-size: 12px;
		color: var(--color-muted);
	}

	.cv-footer a {
		color: var(--color-ink);
	}

	@media (max-width: 768px) {
		.cv {
			padding: 32px 20px;
		}

		.role {
			flex-direction: column;
			gap: 2px;
		}

		.role .dates {
			font-size: 11px;
		}
	}
</style>
