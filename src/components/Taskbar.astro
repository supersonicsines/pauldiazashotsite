---
// Retro OS taskbar: one "application" per language version of the CV. The
// current language's app is depressed; clicking another one switches pages
// while sessionStorage carries the desktop (windows, sections, sidenotes,
// scroll) across, so the switch reads as one workstation, not separate web
// pages. Adding a language = one more entry in APPS + its page under
// src/pages/<code>/.
interface Props {
	lang: 'en' | 'ru' | 'es';
}

const { lang } = Astro.props;

const APPS = [
	{ code: 'en', label: 'English', href: '/' },
	{ code: 'ru', label: 'Русский', href: '/ru/' },
	{ code: 'es', label: 'Español', href: '/es/' },
] as const;

const NAV_LABELS: Record<Props['lang'], string> = {
	en: 'Language switcher',
	ru: 'Переключение языка',
	es: 'Selector de idioma',
};

const navLabel = NAV_LABELS[lang] ?? NAV_LABELS.en;
---

<nav class="taskbar" aria-label={navLabel}>
	<div class="taskbar-apps">
		{
			APPS.map((app) =>
				app.code === lang ? (
					<span class="taskbar-app active" lang={app.code} aria-current="page">
						<span class="taskbar-app-led" aria-hidden="true" />
						<span class="taskbar-app-label">{app.label}</span>
					</span>
				) : (
					<a class="taskbar-app" href={app.href} lang={app.code} data-taskbar-app={app.code}>
						<span class="taskbar-app-led" aria-hidden="true" />
						<span class="taskbar-app-label">{app.label}</span>
					</a>
				)
			)
		}
	</div>
	<div class="taskbar-tray" aria-hidden="true">
		<span class="taskbar-tray-zone">GMT</span>
		<span class="taskbar-tray-divider"></span>
		<span class="taskbar-tray-clock" id="taskbarClock"></span>
	</div>
</nav>

<style>
	.taskbar {
		position: fixed;
		left: 0;
		right: 0;
		bottom: 0;
		z-index: 2000;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 15px;
		padding: 6px 12px calc(6px + env(safe-area-inset-bottom, 0px)) 12px;
		background: var(--color-paper);
		border-top: 1px solid var(--color-bistre);
		box-shadow: 0 -6px 18px rgba(61, 43, 31, 0.12);
		font-family: var(--font-mono);
	}

	/* Inner light edge under the bistre rule: the bar itself is a raised slab. */
	.taskbar::before {
		content: "";
		position: absolute;
		top: 1px;
		left: 0;
		right: 0;
		height: 1px;
		background: rgba(255, 255, 255, 0.75);
		pointer-events: none;
	}

	.taskbar-apps {
		display: flex;
		align-items: stretch;
		gap: 10px;
		min-width: 0;
	}

	/* App buttons: the dock-item bevel vocabulary, one step more dimensional
	   (inset highlights + hard drop), and not a step further. */
	.taskbar-app {
		display: inline-flex;
		align-items: center;
		gap: 9px;
		min-width: 165px;
		padding: 5px 15px 6px 13px;
		box-sizing: border-box;
		background: var(--color-sidenote-bg);
		color: var(--color-bistre);
		font-family: var(--font-mono);
		font-size: 14px;
		font-weight: 700;
		line-height: 1.2;
		text-transform: uppercase;
		letter-spacing: 1.25px;
		text-decoration: none;
		cursor: pointer;
		border: 1px solid;
		border-top-color: #5a4a3a;
		border-left-color: #5a4a3a;
		border-right-color: #1a1410;
		border-bottom-color: #1a1410;
		box-shadow:
			inset 1px 1px 0 rgba(255, 255, 255, 0.7),
			inset -1px -1px 0 rgba(61, 43, 31, 0.24),
			2px 2px 0 rgba(61, 43, 31, 0.32);
	}

	a.taskbar-app:hover {
		background: var(--color-paper);
		color: var(--color-ink);
		box-shadow:
			inset 1px 1px 0 rgba(255, 255, 255, 0.7),
			inset -1px -1px 0 rgba(61, 43, 31, 0.24),
			3px 3px 0 rgba(61, 43, 31, 0.34);
	}

	a.taskbar-app:focus-visible {
		outline: 1px solid var(--color-bistre);
		outline-offset: 2px;
	}

	a.taskbar-app:active {
		transform: translate(1px, 1px);
		box-shadow:
			inset 1px 1px 0 rgba(255, 255, 255, 0.5),
			1px 1px 0 rgba(61, 43, 31, 0.3);
	}

	/* The running application: pressed in, staying in. */
	.taskbar-app.active {
		background: var(--color-paper);
		color: var(--color-ink);
		cursor: default;
		border-top-color: #1a1410;
		border-left-color: #1a1410;
		border-right-color: #5a4a3a;
		border-bottom-color: #5a4a3a;
		box-shadow:
			inset 1px 1px 0 rgba(61, 43, 31, 0.3),
			inset 2px 2px 4px rgba(61, 43, 31, 0.16);
		transform: translate(1px, 1px);
	}

	.taskbar-app-led {
		width: 9px;
		height: 9px;
		flex: 0 0 auto;
		background: var(--color-bistre);
		box-shadow:
			0 0 0 1px var(--color-paper),
			1px 1px 0 rgba(61, 43, 31, 0.35);
		opacity: 0.35;
	}

	.taskbar-app.active .taskbar-app-led {
		opacity: 1;
	}

	.taskbar-app-label {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	/* System tray: inset well with the timezone label and a GMT clock. */
	.taskbar-tray {
		display: inline-flex;
		align-items: stretch;
		gap: 10px;
		padding: 5px 13px 6px 13px;
		background: var(--color-paper);
		font-size: 14px;
		line-height: 1.2;
		letter-spacing: 1.25px;
		color: var(--color-muted);
		border: 1px solid;
		border-top-color: #1a1410;
		border-left-color: #1a1410;
		border-right-color: rgba(255, 255, 255, 0.7);
		border-bottom-color: rgba(255, 255, 255, 0.7);
		box-shadow: inset 1px 1px 2px rgba(61, 43, 31, 0.14);
	}

	.taskbar-tray-zone {
		color: var(--color-ink);
		font-weight: 700;
	}

	.taskbar-tray-divider {
		width: 1px;
		background: rgba(61, 43, 31, 0.25);
		box-shadow: 1px 0 0 rgba(255, 255, 255, 0.7);
	}

	.taskbar-tray-clock {
		font-variant-numeric: tabular-nums;
		min-width: 43px;
		text-align: center;
	}

	@media (max-width: 600px) {
		.taskbar {
			gap: 10px;
		}

		.taskbar-apps {
			flex: 1;
		}

		.taskbar-app {
			min-width: 0;
			flex: 1;
			justify-content: center;
			padding-left: 8px;
			padding-right: 8px;
		}

		.taskbar-tray {
			padding-left: 9px;
			padding-right: 9px;
		}
	}

	@media print {
		.taskbar {
			display: none;
		}
	}
</style>

<script>
	import { requestWarmBoot, updatePdosState } from '../scripts/pdosState';

	document.querySelectorAll<HTMLAnchorElement>('a.taskbar-app[data-taskbar-app]').forEach((link) => {
		link.addEventListener('click', (e) => {
			// Only warm-boot the same-tab navigation; a new tab boots cold.
			if (e.button !== 0 || e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
			updatePdosState((state) => ({ ...state, scrollY: window.scrollY }));
			requestWarmBoot();
		});
	});

	const clock = document.getElementById('taskbarClock');

	// Clock is pinned to GMT so we never touch user location or timezone.
	function renderClock() {
		if (!clock) return;
		const now = new Date();
		const hh = String(now.getUTCHours()).padStart(2, '0');
		const mm = String(now.getUTCMinutes()).padStart(2, '0');
		clock.textContent = `${hh}:${mm}`;
	}

	renderClock();
	window.setInterval(renderClock, 30_000);
</script>
