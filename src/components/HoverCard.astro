---
interface Props {
	term: string;
	id?: string;
}

const { term, id } = Astro.props;
---

<span class="hover-trigger" tabindex="0" role="button" aria-expanded="false" data-id={id}>
	<span class="anchor">{term}</span><span class="hover-card" role="tooltip">
		<span class="hover-card-content"><slot /></span>
	</span>
</span>

<style>
	.hover-trigger {
		position: relative;
		display: inline;
		cursor: pointer;
	}

	.anchor {
		text-decoration: underline;
		text-decoration-color: var(--color-ink);
		text-decoration-thickness: 1.5px;
		text-underline-offset: 3px;
		transition: background-color 160ms ease-out, box-shadow 160ms ease-out;
	}

	.hover-trigger:hover > .anchor,
	.hover-trigger:focus-visible > .anchor,
	.hover-trigger.is-active > .anchor {
		background: var(--color-sidenote-bg);
		box-shadow: 0 0 0 2px var(--color-sidenote-bg);
	}

	.hover-card {
		position: absolute;
		top: calc(1.5em + 8px);
		left: 0;
		width: 400px;
		max-width: calc(100vw - 32px);
		background: var(--color-paper);
		border: 1px solid rgba(61, 43, 31, 0.42);
		border-radius: 14px;
		padding: 18px 22px 17px 22px;
		font-family: var(--font-serif);
		font-size: 15px;
		line-height: 1.55;
		color: var(--color-ink);
		opacity: 0;
		visibility: hidden;
		transform: translateY(4px);
		transition:
			opacity 180ms ease-out 160ms,
			transform 180ms ease-out 160ms,
			visibility 0s 420ms;
		z-index: 50;
		box-shadow:
			0 1px 0 rgba(251, 250, 247, 0.9) inset,
			0 0 0 4px rgba(61, 43, 31, 0.035),
			0 12px 28px rgba(61, 43, 31, 0.16),
			0 3px 8px rgba(61, 43, 31, 0.10);
		text-align: left;
		display: block;
		pointer-events: none;
	}

	.hover-card::before {
		content: "";
		position: absolute;
		inset: 0;
		border-radius: inherit;
		border-top: 5px solid var(--color-bistre);
		opacity: 0.92;
		pointer-events: none;
	}

	.hover-card::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		top: -12px;
		height: 12px;
	}

	.hover-card-content {
		position: relative;
		display: block;
	}

	.hover-card-content::after {
		content: "";
		display: block;
		clear: both;
	}

	.hover-card-content :global(.hc-p) {
		display: block;
		margin: 0 0 10px 0;
	}

	.hover-card-content :global(.hc-p:last-child) {
		margin-bottom: 0;
	}

	.hover-card-content :global(a) {
		text-decoration: underline;
		text-decoration-color: var(--color-rule);
		color: var(--color-ink);
	}

	.hover-card-content :global(.further-reading) {
		clear: both;
		margin-top: 14px;
		padding-top: 12px;
		border-top: 1px solid rgba(61, 43, 31, 0.18);
		font-size: 13px;
		color: var(--color-muted);
	}

	.hover-card-content :global(.hc-media) {
		display: block;
		margin: 2px 0 12px 0;
		border: 1px solid rgba(61, 43, 31, 0.22);
		background: var(--color-sidenote-bg);
		overflow: hidden;
	}

	.hover-card-content :global(.hc-media--half) {
		float: right;
		width: 50%;
		margin: 2px 0 10px 14px;
	}

	.hover-card-content :global(.hc-media img) {
		display: block;
		width: 100%;
		height: auto;
		filter: saturate(0.92) contrast(0.98);
	}

	.hover-card-content :global(.hc-quote) {
		display: block;
		margin: 10px 0;
		padding-left: 14px;
		border-left: 2px solid var(--color-rule);
		font-style: italic;
		color: var(--color-muted);
	}

	/* Hover behavior on devices that support it */
	@media (hover: hover) {
		.hover-trigger:hover > .hover-card,
		.hover-trigger:focus-visible > .hover-card,
		.hover-card:hover {
			opacity: 1;
			visibility: visible;
			transform: translateY(0);
			pointer-events: auto;
			transition:
				opacity 200ms ease-out 140ms,
				transform 200ms ease-out 140ms,
				visibility 0s 0s;
		}
	}

	@media (max-width: 600px) {
		.hover-card {
			left: 50%;
			width: min(400px, calc(100vw - 32px));
			transform: translate(-50%, 4px);
		}

		.hover-card-content :global(.hc-media--half) {
			float: none;
			width: 100%;
			margin: 2px 0 12px 0;
		}

		@media (hover: hover) {
			.hover-trigger:hover > .hover-card,
			.hover-trigger:focus-visible > .hover-card,
			.hover-card:hover {
				transform: translate(-50%, 0);
			}
		}
	}

	:global(body.hover-card-portal-ready) .hover-card {
		position: fixed;
		top: 0;
		left: 0;
		width: min(400px, calc(100vw - 32px));
		max-height: calc(100vh - 32px);
		overflow: auto;
		z-index: 500;
	}

	:global(body.hover-card-portal-ready) .hover-card.is-visible {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
		pointer-events: auto;
		transition:
			opacity 200ms ease-out 140ms,
			transform 200ms ease-out 140ms,
			visibility 0s 0s;
	}

	:global(.hover-card-mobile-inline) {
		display: none;
		margin: 8px 0 10px 0;
		background: var(--color-sidenote-bg);
		border-left: 2px solid var(--color-rule);
		padding: 10px 14px 12px 14px;
		font-family: var(--font-serif);
		font-size: 14px;
		line-height: 1.55;
		color: var(--color-ink);
	}

	:global(.hover-card-mobile-inline-title) {
		margin: 0 0 8px 0;
		font-family: var(--font-serif);
		font-size: 12px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: var(--color-bistre);
	}

	:global(.hover-card-mobile-inline-content .hc-p) {
		display: block;
		margin: 0 0 10px 0;
	}

	:global(.hover-card-mobile-inline-content .hc-p:last-child) {
		margin-bottom: 0;
	}

	@media (max-width: 700px), (hover: none) and (pointer: coarse) {
		:global(.hover-card-mobile-inline.open) {
			display: block;
		}
	}
</style>

<script>
	const HOVER_CARD_MARGIN = 16;
	const HOVER_CARD_GAP = 12;
	const MOBILE_INLINE_QUERY = '(max-width: 700px), (hover: none) and (pointer: coarse)';

	function clamp(value: number, min: number, max: number) {
		return Math.min(Math.max(value, min), max);
	}

	function positionCard(trigger: HTMLElement, card: HTMLElement) {
		const triggerRect = trigger.getBoundingClientRect();
		const viewportWidth = window.innerWidth;
		const viewportHeight = window.innerHeight;
		const cardWidth = Math.min(card.offsetWidth, viewportWidth - HOVER_CARD_MARGIN * 2);
		const cardHeight = Math.min(card.offsetHeight, viewportHeight - HOVER_CARD_MARGIN * 2);

		let left = triggerRect.left;
		let top = triggerRect.bottom + HOVER_CARD_GAP;

		if (top + cardHeight > viewportHeight - HOVER_CARD_MARGIN) {
			top = triggerRect.top - cardHeight - HOVER_CARD_GAP;
		}

		left = clamp(left, HOVER_CARD_MARGIN, viewportWidth - cardWidth - HOVER_CARD_MARGIN);
		top = clamp(top, HOVER_CARD_MARGIN, viewportHeight - cardHeight - HOVER_CARD_MARGIN);

		card.style.left = `${Math.round(left)}px`;
		card.style.top = `${Math.round(top)}px`;
	}

	function initHoverCards() {
		if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

		document.body.classList.add('hover-card-portal-ready');

		document.querySelectorAll<HTMLElement>('.hover-trigger').forEach((trigger) => {
			const card = trigger.querySelector<HTMLElement>('.hover-card');
			if (!card) return;

			let hideTimer: number | undefined;

			function clearHideTimer() {
				if (hideTimer) {
					window.clearTimeout(hideTimer);
					hideTimer = undefined;
				}
			}

			function show() {
				clearHideTimer();
				if (card.parentElement !== document.body) {
					document.body.appendChild(card);
				}
				trigger.classList.add('is-active');
				positionCard(trigger, card);
				card.classList.add('is-visible');
			}

			function hide() {
				trigger.classList.remove('is-active');
				card.classList.remove('is-visible');
			}

			function scheduleHide() {
				clearHideTimer();
				hideTimer = window.setTimeout(hide, 140);
			}

			trigger.addEventListener('mouseenter', show);
			trigger.addEventListener('mouseleave', scheduleHide);
			card.addEventListener('mouseenter', clearHideTimer);
			card.addEventListener('mouseleave', scheduleHide);

			trigger.addEventListener('focusin', () => {
				window.requestAnimationFrame(() => {
					if (trigger.matches(':focus-visible')) show();
				});
			});
			trigger.addEventListener('focusout', scheduleHide);

			window.addEventListener('scroll', () => {
				if (card.classList.contains('is-visible')) positionCard(trigger, card);
			}, { passive: true });
			window.addEventListener('resize', () => {
				if (card.classList.contains('is-visible')) positionCard(trigger, card);
			});
		});
	}

	function initMobileHoverCards() {
		const mobileInlineQuery = window.matchMedia(MOBILE_INLINE_QUERY);
		const mobilePanels = new Map<HTMLElement, HTMLElement>();

		document.querySelectorAll<HTMLElement>('.hover-trigger').forEach((trigger, index) => {
			const card = trigger.querySelector<HTMLElement>('.hover-card');
			const sourceContent = card?.querySelector<HTMLElement>('.hover-card-content');
			if (!sourceContent) return;

			function getTitle() {
				return trigger.querySelector<HTMLElement>('.anchor')?.textContent?.trim() ?? 'More';
			}

			function isMobileInlineMode() {
				return mobileInlineQuery.matches;
			}

			function ensureMobilePanel() {
				const existing = mobilePanels.get(trigger);
				if (existing) return existing;

				const anchor = trigger.closest<HTMLElement>('.role') ?? trigger.closest<HTMLElement>('li') ?? trigger;
				const panel = document.createElement('div');
				const title = document.createElement('div');
				const content = document.createElement('div');
				const panelId = `hover-card-mobile-${index}`;

				panel.className = 'mobile-window-inline hover-card-mobile-inline';
				panel.id = panelId;
				panel.dataset.mobileHoverCard = 'true';
				title.className = 'mobile-window-inline-title hover-card-mobile-inline-title';
				title.textContent = getTitle();
				content.className = 'mobile-window-inline-content hover-card-mobile-inline-content';
				content.append(...Array.from(sourceContent.childNodes).map((node) => node.cloneNode(true)));

				panel.append(title, content);
				anchor.insertAdjacentElement('afterend', panel);
				trigger.setAttribute('aria-controls', panelId);
				mobilePanels.set(trigger, panel);
				return panel;
			}

			function closeMobilePanel() {
				const panel = mobilePanels.get(trigger);
				if (!panel) return;
				panel.classList.remove('open');
				trigger.classList.remove('is-active');
				trigger.setAttribute('aria-expanded', 'false');
			}

			function toggleMobilePanel(event: MouseEvent | KeyboardEvent) {
				if (!isMobileInlineMode()) return;

				event.preventDefault();
				const panel = ensureMobilePanel();
				const willOpen = !panel.classList.contains('open');

				panel.classList.toggle('open', willOpen);
				trigger.classList.toggle('is-active', willOpen);
				trigger.setAttribute('aria-expanded', String(willOpen));
			}

			trigger.addEventListener('click', toggleMobilePanel);
			trigger.addEventListener('keydown', (event) => {
				if (event.key !== 'Enter' && event.key !== ' ') return;
				toggleMobilePanel(event);
			});

			mobileInlineQuery.addEventListener('change', (event) => {
				if (!event.matches) closeMobilePanel();
			});
		});
	}

	initHoverCards();
	initMobileHoverCards();
</script>
