---
interface Props {
	term: string;
	id?: string;
}

const { term, id } = Astro.props;
---

<span class="hover-trigger" tabindex="0" data-id={id}>
	<span class="anchor">{term}</span>
	<span class="hover-card" role="tooltip">
		<button class="close-btn" aria-label="Close">×</button>
		<div class="hover-card-content">
			<slot />
		</div>
	</span>
</span>

<style>
	.hover-trigger {
		position: relative;
		display: inline;
		cursor: pointer;
	}

	.anchor {
		text-decoration: underline;
		text-decoration-color: var(--color-ink);
		text-decoration-thickness: 1.5px;
		text-underline-offset: 3px;
	}

	.hover-card {
		position: absolute;
		top: calc(100% + 8px);
		left: 0;
		width: 380px;
		max-width: calc(100vw - 32px);
		background: var(--color-paper);
		border: 0.5px solid var(--color-rule);
		padding: 16px 20px;
		font-family: var(--font-serif);
		font-size: 15px;
		line-height: 1.5;
		color: var(--color-ink);
		opacity: 0;
		visibility: hidden;
		transition: opacity 200ms ease-out 200ms, visibility 0s 600ms;
		z-index: 50;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
		text-align: left;
	}

	.hover-card-content :global(.hc-p) {
		margin: 0 0 8px 0;
		display: block;
	}

	.hover-card-content :global(.hc-p:last-child) {
		margin-bottom: 0;
	}

	.hover-card-content :global(a) {
		text-decoration: underline;
		text-decoration-color: var(--color-rule);
	}

	.hover-card-content :global(.further-reading) {
		margin-top: 12px;
		padding-top: 12px;
		border-top: 0.5px solid var(--color-rule);
		font-size: 13px;
		color: var(--color-muted);
	}

	.hover-card-content :global(.hc-quote) {
		display: block;
		margin: 8px 0;
		padding-left: 12px;
		border-left: 2px solid var(--color-rule);
		font-style: italic;
		color: var(--color-muted);
	}

	.close-btn {
		display: none;
		position: absolute;
		top: 8px;
		right: 12px;
		background: none;
		border: none;
		font-family: var(--font-serif);
		font-size: 22px;
		line-height: 1;
		color: var(--color-muted);
		cursor: pointer;
		padding: 0;
	}

	/* Desktop: hover behavior */
	@media (min-width: 769px) and (hover: hover) {
		.hover-trigger:hover .hover-card,
		.hover-trigger:focus-within .hover-card,
		.hover-card:hover {
			opacity: 1;
			visibility: visible;
			transition: opacity 250ms ease-out 200ms, visibility 0s 0s;
		}
	}

	/* Mobile: tap to toggle, modal-style */
	@media (max-width: 768px), (hover: none) {
		.close-btn {
			display: block;
		}

		.hover-trigger.open .hover-card {
			position: fixed;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			width: calc(100vw - 32px);
			max-width: 420px;
			max-height: 70vh;
			overflow-y: auto;
			opacity: 1;
			visibility: visible;
			transition: opacity 200ms ease-out;
			z-index: 200;
			box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
		}
	}
</style>

<script>
	function initHoverCards() {
		const triggers = document.querySelectorAll('.hover-trigger');

		triggers.forEach((trigger) => {
			const closeBtn = trigger.querySelector('.close-btn');

			// Mobile: tap to open
			trigger.addEventListener('click', (e) => {
				if (window.matchMedia('(hover: none), (max-width: 768px)').matches) {
					if ((e.target as Element).classList.contains('close-btn')) {
						return;
					}
					e.preventDefault();
					document.querySelectorAll('.hover-trigger.open').forEach((t) => {
						if (t !== trigger) t.classList.remove('open');
					});
					trigger.classList.toggle('open');
				}
			});

			// Close button
			if (closeBtn) {
				closeBtn.addEventListener('click', (e) => {
					e.stopPropagation();
					trigger.classList.remove('open');
				});
			}
		});

		// Close on escape
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				document.querySelectorAll('.hover-trigger.open').forEach((t) => {
					t.classList.remove('open');
				});
			}
		});
	}

	initHoverCards();
	document.addEventListener('astro:page-load', initHoverCards);
</script>
