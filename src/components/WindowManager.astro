---
// WindowManager: place once at the body level. Renders the dock and
// initializes drag/resize/minimize/close handlers for all <Window> elements.
---

<div id="windowDock" class="window-dock"></div>

<style>
	.window-dock {
		--dock-item-width: 286px;
		position: fixed;
		top: 96px;
		left: 12px;
		width: calc(var(--dock-item-width) + 18px);
		box-sizing: border-box;
		display: none;
		flex-direction: column;
		gap: 8px;
		padding: 28px 8px 8px 8px;
		background: var(--color-paper);
		border: 1px solid var(--color-bistre);
		box-shadow: 3px 3px 0 var(--color-bistre), 0 8px 22px rgba(61, 43, 31, 0.18);
		z-index: 400;
		font-family: var(--font-mono);
	}

	.window-dock::before {
		content: "";
		position: absolute;
		top: 8px;
		left: 8px;
		right: 8px;
		height: 10px;
		background:
			repeating-linear-gradient(
				to right,
				var(--color-bistre) 0,
				var(--color-bistre) 1px,
				transparent 1px,
				transparent 4px
			);
		opacity: 0.62;
	}

	.window-dock::after {
		content: "";
		position: absolute;
		inset: 2px;
		border-top: 1px solid rgba(255, 255, 255, 0.65);
		border-left: 1px solid rgba(255, 255, 255, 0.65);
		pointer-events: none;
	}

	.window-dock.has-windows {
		display: flex;
		align-items: stretch;
	}

	:global(.dock-item) {
		all: unset;
		display: grid;
		grid-template-rows: auto 1fr;
		position: relative;
		width: var(--dock-item-width);
		box-sizing: border-box;
		background: var(--color-sidenote-bg);
		color: var(--color-ink);
		font-family: var(--font-mono);
		border: 1px solid var(--color-bistre);
		border-top: 1px solid #5a4a3a;
		border-left: 1px solid #5a4a3a;
		border-right: 1px solid #1a1410;
		border-bottom: 1px solid #1a1410;
		box-shadow: 2px 2px 0 rgba(61, 43, 31, 0.32);
	}

	:global(.dock-item-titlebar) {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 18px;
		align-items: center;
		background: var(--color-bistre);
		color: var(--color-paper);
	}

	:global(.dock-restore),
	:global(.dock-close) {
		all: unset;
		cursor: pointer;
		font-family: var(--font-mono);
	}

	:global(.dock-title-button) {
		min-width: 0;
	}

	:global(.dock-item-title) {
		display: block;
		min-width: 0;
		padding: 3px 8px 3px 9px;
		color: var(--color-paper);
		font-size: 11px;
		font-weight: 700;
		line-height: 1.1;
		text-transform: uppercase;
		letter-spacing: 1px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	:global(.dock-close) {
		width: 16px;
		height: 16px;
		margin-right: 2px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: var(--color-paper);
		color: var(--color-bistre);
		font-size: 12px;
		font-weight: 700;
		line-height: 1;
		border: 1px solid var(--color-paper);
	}

	:global(.dock-close:hover),
	:global(.dock-close:focus-visible) {
		background: #b94a3a;
		color: var(--color-paper);
		border-color: #b94a3a;
	}

	:global(.dock-item-body) {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 5px 8px 6px 9px;
		font-size: 11px;
		line-height: 1;
		color: var(--color-bistre);
		background:
			linear-gradient(180deg, rgba(251, 250, 247, 0.88), rgba(242, 239, 232, 0.92));
	}

	:global(.dock-item-led) {
		width: 7px;
		height: 7px;
		background: var(--color-bistre);
		box-shadow: 0 0 0 1px var(--color-paper), 1px 1px 0 rgba(61, 43, 31, 0.35);
		flex: 0 0 auto;
	}

	:global(.dock-item-path) {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		font-style: italic;
		color: var(--color-muted);
	}

	:global(.dock-item:hover),
	:global(.dock-item:focus-within) {
		background: var(--color-paper);
		box-shadow: 3px 3px 0 var(--color-bistre);
	}

	:global(.dock-item:hover .dock-item-titlebar),
	:global(.dock-item:focus-within .dock-item-titlebar) {
		background: #4d3b2a;
	}

	:global(.dock-restore:focus-visible),
	:global(.dock-close:focus-visible) {
		outline: 1px solid var(--color-bistre);
		outline-offset: 2px;
	}

	:global(.dock-item:active) {
		border-top: 1px solid #1a1410;
		border-left: 1px solid #1a1410;
		border-right: 1px solid #5a4a3a;
		border-bottom: 1px solid #5a4a3a;
		box-shadow: 1px 1px 0 rgba(61, 43, 31, 0.4);
		transform: translate(1px, 1px);
	}

	:global(.mobile-window-inline) {
		display: none;
		margin: 8px 0 10px 0;
		background: var(--color-sidenote-bg);
		border-left: 2px solid var(--color-rule);
		padding: 10px 14px 12px 14px;
		font-family: var(--font-serif);
		font-size: 14px;
		line-height: 1.55;
		color: var(--color-ink);
	}

	:global(.mobile-window-inline-title) {
		margin: 0 0 8px 0;
		font-family: var(--font-serif);
		font-size: 12px;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 1px;
		color: var(--color-bistre);
	}

	:global(.mobile-window-inline-content p) {
		margin: 0 0 10px 0;
	}

	:global(.mobile-window-inline-content p:last-child) {
		margin-bottom: 0;
	}

	@media (max-width: 700px), (hover: none) and (pointer: coarse) {
		.window-dock {
			display: none !important;
		}

		:global(.window) {
			display: none !important;
		}

		:global(.mobile-window-inline.open) {
			display: block;
		}
	}
</style>

<script>
	const MOBILE_INLINE_QUERY = '(max-width: 700px), (hover: none) and (pointer: coarse)';

	type WinState = {
		element: HTMLElement;
		minimized: boolean;
	};

	let dragState: {
		element: HTMLElement;
		offsetX: number;
		offsetY: number;
	} | null = null;

	let resizeState: {
		element: HTMLElement;
		startX: number;
		startY: number;
		startW: number;
		startH: number;
	} | null = null;

	let zCounter = 300;

	function getEventPoint(e: MouseEvent | TouchEvent) {
		if ('touches' in e) {
			const t = e.touches[0] || e.changedTouches[0];
			return { x: t.clientX, y: t.clientY };
		}
		return { x: e.clientX, y: e.clientY };
	}

	function bringToFront(win: HTMLElement) {
		zCounter += 1;
		win.style.zIndex = String(zCounter);
	}

	function escapeHtml(value: string) {
		return value
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;');
	}

	function initWindowManager() {
		const dock = document.getElementById('windowDock');
		if (!dock) return;

		const windows = new Map<string, WinState>();
		const mobilePanels = new Map<string, HTMLElement>();
		const mobileInlineQuery = window.matchMedia(MOBILE_INLINE_QUERY);

		document.querySelectorAll<HTMLElement>('.window[data-window-id]').forEach((win) => {
			const id = win.dataset.windowId!;
			windows.set(id, { element: win, minimized: false });

			const titlebar = win.querySelector<HTMLElement>('.window-titlebar');
			const closeBtn = win.querySelector<HTMLButtonElement>('.window-close');
			const minBtn = win.querySelector<HTMLButtonElement>('.window-minimize');
			const handle = win.querySelector<HTMLElement>('.window-resize-handle');

			closeBtn?.addEventListener('click', (e) => {
				e.stopPropagation();
				closeWindow(id);
			});

			minBtn?.addEventListener('click', (e) => {
				e.stopPropagation();
				minimizeWindow(id);
			});

			win.addEventListener('mousedown', () => bringToFront(win));
			win.addEventListener('touchstart', () => bringToFront(win), { passive: true });

			titlebar?.addEventListener('mousedown', (e) => startDrag(win, e));
			titlebar?.addEventListener('touchstart', (e) => startDrag(win, e), { passive: false });

			handle?.addEventListener('mousedown', (e) => startResize(win, e));
			handle?.addEventListener('touchstart', (e) => startResize(win, e), { passive: false });
		});

		document.querySelectorAll<HTMLElement>('[data-window-trigger]').forEach((trigger) => {
			trigger.setAttribute('aria-expanded', 'false');
			trigger.addEventListener('click', (e) => {
				e.preventDefault();
				const id = trigger.dataset.windowTrigger!;
				if (isMobileInlineMode()) {
					toggleMobileWindow(id, trigger);
				} else {
					openWindow(id);
				}
			});
		});

		function isMobileInlineMode() {
			return mobileInlineQuery.matches;
		}

		function getTitle(id: string) {
			const w = windows.get(id);
			return w?.element.querySelector('.window-title')?.textContent ?? id;
		}

		function ensureMobilePanel(id: string, trigger: HTMLElement) {
			const existing = mobilePanels.get(id);
			if (existing) return existing;

			const w = windows.get(id);
			if (!w) return null;

			const sourceContent = w.element.querySelector<HTMLElement>('.window-content');
			const anchor = trigger.closest<HTMLElement>('.role') ?? trigger.closest<HTMLElement>('li') ?? trigger;
			const panel = document.createElement('div');
			const title = document.createElement('div');
			const content = document.createElement('div');

			panel.className = 'mobile-window-inline';
			panel.dataset.mobileWindowId = id;
			title.className = 'mobile-window-inline-title';
			title.textContent = getTitle(id);
			content.className = 'mobile-window-inline-content';

			if (sourceContent) {
				content.append(...Array.from(sourceContent.childNodes).map((node) => node.cloneNode(true)));
			}

			panel.append(title, content);
			anchor.insertAdjacentElement('afterend', panel);
			mobilePanels.set(id, panel);
			return panel;
		}

		function toggleMobileWindow(id: string, trigger: HTMLElement) {
			const panel = ensureMobilePanel(id, trigger);
			if (!panel) return;

			const willOpen = !panel.classList.contains('open');
			panel.classList.toggle('open', willOpen);
			trigger.setAttribute('aria-expanded', String(willOpen));
		}

		function closeAllMobilePanels() {
			mobilePanels.forEach((panel) => panel.classList.remove('open'));
			document.querySelectorAll<HTMLElement>('[data-window-trigger]').forEach((trigger) => {
				trigger.setAttribute('aria-expanded', 'false');
			});
		}

		function closeAllWindowsForMobile() {
			windows.forEach((w) => {
				w.element.classList.remove('open', 'minimized');
				w.minimized = false;
			});
			renderDock();
		}

		// Mobile deliberately avoids the draggable/minimizable window model.
		// Role detail opens inline like a dagger note so document flow stays natural.
		mobileInlineQuery.addEventListener('change', (e) => {
			if (e.matches) {
				closeAllWindowsForMobile();
			} else {
				closeAllMobilePanels();
			}
		});

		function openWindow(id: string) {
			if (isMobileInlineMode()) return;
			const w = windows.get(id);
			if (!w) return;
			w.element.classList.add('open');
			w.element.classList.remove('minimized');
			w.minimized = false;
			bringToFront(w.element);
			renderDock();
		}

		function closeWindow(id: string) {
			const w = windows.get(id);
			if (!w) return;
			w.element.classList.remove('open', 'minimized');
			w.minimized = false;
			renderDock();
		}

		function minimizeWindow(id: string) {
			if (isMobileInlineMode()) return;
			const w = windows.get(id);
			if (!w) return;
			w.element.classList.add('minimized');
			w.minimized = true;
			renderDock();
		}

		function renderDock() {
			const minimized = [...windows.entries()].filter(([_, w]) => w.minimized);
			if (minimized.length === 0) {
				dock!.classList.remove('has-windows');
				dock!.innerHTML = '';
				return;
			}
			dock!.classList.add('has-windows');
			dock!.innerHTML = minimized
				.map(([id, w]) => {
					const title = w.element.querySelector('.window-title')?.textContent ?? id;
					const safeTitle = escapeHtml(title);
					const safeId = escapeHtml(id);
					return `
						<div class="dock-item" data-dock-id="${safeId}">
							<div class="dock-item-titlebar">
								<button class="dock-restore dock-title-button" data-dock-restore-id="${safeId}" aria-label="Restore ${safeTitle}">
									<span class="dock-item-title">${safeTitle}</span>
								</button>
								<button class="dock-close" data-dock-close-id="${safeId}" aria-label="Close ${safeTitle}">×</button>
							</div>
							<button class="dock-restore dock-item-body" data-dock-restore-id="${safeId}" aria-label="Restore ${safeTitle}">
								<span class="dock-item-led" aria-hidden="true"></span>
								<span class="dock-item-path">~/cv/${safeId}</span>
							</button>
						</div>
					`;
				})
				.join('');
			dock!.querySelectorAll<HTMLButtonElement>('[data-dock-restore-id]').forEach((btn) => {
				btn.addEventListener('click', () => {
					openWindow(btn.dataset.dockRestoreId!);
				});
			});
			dock!.querySelectorAll<HTMLButtonElement>('[data-dock-close-id]').forEach((btn) => {
				btn.addEventListener('click', (e) => {
					e.stopPropagation();
					closeWindow(btn.dataset.dockCloseId!);
				});
			});
		}

		function startDrag(win: HTMLElement, e: MouseEvent | TouchEvent) {
			const target = e.target as HTMLElement;
			if (target.closest('.window-controls')) return;
			const rect = win.getBoundingClientRect();
			const point = getEventPoint(e);
			dragState = {
				element: win,
				offsetX: point.x - rect.left,
				offsetY: point.y - rect.top,
			};
			win.classList.add('dragging');
			bringToFront(win);
			if (e.cancelable) e.preventDefault();
		}

		function startResize(win: HTMLElement, e: MouseEvent | TouchEvent) {
			const point = getEventPoint(e);
			const rect = win.getBoundingClientRect();
			resizeState = {
				element: win,
				startX: point.x,
				startY: point.y,
				startW: rect.width,
				startH: rect.height,
			};
			win.classList.add('resizing');
			if (e.cancelable) e.preventDefault();
		}

		function onMove(e: MouseEvent | TouchEvent) {
			const point = getEventPoint(e);
			if (dragState) {
				const x = point.x - dragState.offsetX;
				const y = point.y - dragState.offsetY;
				dragState.element.style.left = x + 'px';
				dragState.element.style.top = y + 'px';
				if (e.cancelable) e.preventDefault();
			} else if (resizeState) {
				const dx = point.x - resizeState.startX;
				const dy = point.y - resizeState.startY;
				const w = Math.max(280, resizeState.startW + dx);
				const h = Math.max(200, resizeState.startH + dy);
				resizeState.element.style.width = w + 'px';
				resizeState.element.style.height = h + 'px';
				if (e.cancelable) e.preventDefault();
			}
		}

		function onEnd() {
			if (dragState) {
				dragState.element.classList.remove('dragging');
				dragState = null;
			}
			if (resizeState) {
				resizeState.element.classList.remove('resizing');
				resizeState = null;
			}
		}

		document.addEventListener('mousemove', onMove);
		document.addEventListener('mouseup', onEnd);
		document.addEventListener('touchmove', onMove, { passive: false });
		document.addEventListener('touchend', onEnd);

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				windows.forEach((w, id) => {
					if (w.element.classList.contains('open') && !w.minimized) {
						closeWindow(id);
					}
				});
			}
		});
	}

	initWindowManager();
</script>
