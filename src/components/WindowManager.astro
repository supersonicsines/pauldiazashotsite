---
// WindowManager: place once at the body level. Renders the dock and
// initializes drag/resize/minimize/close handlers for all <Window> elements.
---

<div id="windowDock" class="window-dock"></div>

<style>
	.window-dock {
		position: fixed;
		bottom: 12px;
		left: 50%;
		transform: translateX(-50%);
		width: min(760px, calc(100vw - 24px));
		display: none;
		gap: 8px;
		padding: 7px 9px 8px 28px;
		background: var(--color-paper);
		border: 1px solid var(--color-bistre);
		box-shadow: 3px 3px 0 var(--color-bistre), 0 8px 22px rgba(61, 43, 31, 0.18);
		z-index: 400;
		font-family: var(--font-mono);
		min-height: 38px;
	}

	.window-dock::before {
		content: "";
		position: absolute;
		top: 7px;
		bottom: 7px;
		left: 9px;
		width: 10px;
		background:
			repeating-linear-gradient(
				to bottom,
				var(--color-bistre) 0,
				var(--color-bistre) 1px,
				transparent 1px,
				transparent 4px
			);
		opacity: 0.62;
	}

	.window-dock::after {
		content: "";
		position: absolute;
		inset: 2px;
		border-top: 1px solid rgba(255, 255, 255, 0.65);
		border-left: 1px solid rgba(255, 255, 255, 0.65);
		pointer-events: none;
	}

	.window-dock.has-windows {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
	}

	.dock-item {
		all: unset;
		display: grid;
		grid-template-rows: auto 1fr;
		min-width: 172px;
		max-width: 240px;
		background: var(--color-sidenote-bg);
		color: var(--color-ink);
		cursor: pointer;
		font-family: var(--font-mono);
		border: 1px solid var(--color-bistre);
		border-top: 1px solid #5a4a3a;
		border-left: 1px solid #5a4a3a;
		border-right: 1px solid #1a1410;
		border-bottom: 1px solid #1a1410;
		box-shadow: 2px 2px 0 rgba(61, 43, 31, 0.32);
	}

	.dock-item-title {
		display: block;
		min-width: 0;
		padding: 3px 8px 3px 9px;
		background: var(--color-bistre);
		color: var(--color-paper);
		font-size: 11px;
		font-weight: 700;
		line-height: 1.1;
		text-transform: uppercase;
		letter-spacing: 1px;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.dock-item-body {
		display: flex;
		align-items: center;
		gap: 6px;
		padding: 5px 8px 6px 9px;
		font-size: 11px;
		line-height: 1;
		color: var(--color-bistre);
		background:
			linear-gradient(180deg, rgba(251, 250, 247, 0.88), rgba(242, 239, 232, 0.92));
	}

	.dock-item-led {
		width: 7px;
		height: 7px;
		background: var(--color-bistre);
		box-shadow: 0 0 0 1px var(--color-paper), 1px 1px 0 rgba(61, 43, 31, 0.35);
		flex: 0 0 auto;
	}

	.dock-item-path {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		font-style: italic;
		color: var(--color-muted);
	}

	.dock-item:hover,
	.dock-item:focus-visible {
		background: var(--color-paper);
		box-shadow: 3px 3px 0 var(--color-bistre);
	}

	.dock-item:hover .dock-item-title,
	.dock-item:focus-visible .dock-item-title {
		background: #4d3b2a;
	}

	.dock-item:focus-visible {
		outline: 1px solid var(--color-bistre);
		outline-offset: 3px;
	}

	.dock-item:active {
		border-top: 1px solid #1a1410;
		border-left: 1px solid #1a1410;
		border-right: 1px solid #5a4a3a;
		border-bottom: 1px solid #5a4a3a;
		box-shadow: 1px 1px 0 rgba(61, 43, 31, 0.4);
		transform: translate(1px, 1px);
	}

	@media (max-width: 600px) {
		.window-dock {
			bottom: 8px;
			width: calc(100vw - 16px);
			padding-left: 24px;
		}

		.dock-item {
			min-width: min(220px, calc(100vw - 64px));
			max-width: calc(100vw - 64px);
		}
	}
</style>

<script>
	type WinState = {
		element: HTMLElement;
		minimized: boolean;
	};

	let dragState: {
		element: HTMLElement;
		offsetX: number;
		offsetY: number;
	} | null = null;

	let resizeState: {
		element: HTMLElement;
		startX: number;
		startY: number;
		startW: number;
		startH: number;
	} | null = null;

	let zCounter = 300;

	function getEventPoint(e: MouseEvent | TouchEvent) {
		if ('touches' in e) {
			const t = e.touches[0] || e.changedTouches[0];
			return { x: t.clientX, y: t.clientY };
		}
		return { x: e.clientX, y: e.clientY };
	}

	function bringToFront(win: HTMLElement) {
		zCounter += 1;
		win.style.zIndex = String(zCounter);
	}

	function escapeHtml(value: string) {
		return value
			.replaceAll('&', '&amp;')
			.replaceAll('<', '&lt;')
			.replaceAll('>', '&gt;')
			.replaceAll('"', '&quot;');
	}

	function initWindowManager() {
		const dock = document.getElementById('windowDock');
		if (!dock) return;

		const windows = new Map<string, WinState>();

		document.querySelectorAll<HTMLElement>('.window[data-window-id]').forEach((win) => {
			const id = win.dataset.windowId!;
			windows.set(id, { element: win, minimized: false });

			const titlebar = win.querySelector<HTMLElement>('.window-titlebar');
			const closeBtn = win.querySelector<HTMLButtonElement>('.window-close');
			const minBtn = win.querySelector<HTMLButtonElement>('.window-minimize');
			const handle = win.querySelector<HTMLElement>('.window-resize-handle');

			closeBtn?.addEventListener('click', (e) => {
				e.stopPropagation();
				closeWindow(id);
			});

			minBtn?.addEventListener('click', (e) => {
				e.stopPropagation();
				minimizeWindow(id);
			});

			win.addEventListener('mousedown', () => bringToFront(win));
			win.addEventListener('touchstart', () => bringToFront(win), { passive: true });

			titlebar?.addEventListener('mousedown', (e) => startDrag(win, e));
			titlebar?.addEventListener('touchstart', (e) => startDrag(win, e), { passive: false });

			handle?.addEventListener('mousedown', (e) => startResize(win, e));
			handle?.addEventListener('touchstart', (e) => startResize(win, e), { passive: false });
		});

		document.querySelectorAll<HTMLElement>('[data-window-trigger]').forEach((trigger) => {
			trigger.addEventListener('click', (e) => {
				e.preventDefault();
				const id = trigger.dataset.windowTrigger!;
				openWindow(id);
			});
		});

		function openWindow(id: string) {
			const w = windows.get(id);
			if (!w) return;
			w.element.classList.add('open');
			w.element.classList.remove('minimized');
			w.minimized = false;
			bringToFront(w.element);
			renderDock();
		}

		function closeWindow(id: string) {
			const w = windows.get(id);
			if (!w) return;
			w.element.classList.remove('open', 'minimized');
			w.minimized = false;
			renderDock();
		}

		function minimizeWindow(id: string) {
			const w = windows.get(id);
			if (!w) return;
			w.element.classList.add('minimized');
			w.minimized = true;
			renderDock();
		}

		function renderDock() {
			const minimized = [...windows.entries()].filter(([_, w]) => w.minimized);
			if (minimized.length === 0) {
				dock!.classList.remove('has-windows');
				dock!.innerHTML = '';
				return;
			}
			dock!.classList.add('has-windows');
			dock!.innerHTML = minimized
				.map(([id, w]) => {
					const title = w.element.querySelector('.window-title')?.textContent ?? id;
					const safeTitle = escapeHtml(title);
					const safeId = escapeHtml(id);
					return `
						<button class="dock-item" data-dock-id="${safeId}" aria-label="Restore ${safeTitle}">
							<span class="dock-item-title">${safeTitle}</span>
							<span class="dock-item-body">
								<span class="dock-item-led" aria-hidden="true"></span>
								<span class="dock-item-path">~/cv/${safeId}</span>
							</span>
						</button>
					`;
				})
				.join('');
			dock!.querySelectorAll<HTMLButtonElement>('.dock-item').forEach((btn) => {
				btn.addEventListener('click', () => {
					openWindow(btn.dataset.dockId!);
				});
			});
		}

		function startDrag(win: HTMLElement, e: MouseEvent | TouchEvent) {
			const target = e.target as HTMLElement;
			if (target.closest('.window-controls')) return;
			const rect = win.getBoundingClientRect();
			const point = getEventPoint(e);
			dragState = {
				element: win,
				offsetX: point.x - rect.left,
				offsetY: point.y - rect.top,
			};
			win.classList.add('dragging');
			bringToFront(win);
			if (e.cancelable) e.preventDefault();
		}

		function startResize(win: HTMLElement, e: MouseEvent | TouchEvent) {
			const point = getEventPoint(e);
			const rect = win.getBoundingClientRect();
			resizeState = {
				element: win,
				startX: point.x,
				startY: point.y,
				startW: rect.width,
				startH: rect.height,
			};
			win.classList.add('resizing');
			if (e.cancelable) e.preventDefault();
		}

		function onMove(e: MouseEvent | TouchEvent) {
			const point = getEventPoint(e);
			if (dragState) {
				const x = point.x - dragState.offsetX;
				const y = point.y - dragState.offsetY;
				dragState.element.style.left = x + 'px';
				dragState.element.style.top = y + 'px';
				if (e.cancelable) e.preventDefault();
			} else if (resizeState) {
				const dx = point.x - resizeState.startX;
				const dy = point.y - resizeState.startY;
				const w = Math.max(280, resizeState.startW + dx);
				const h = Math.max(200, resizeState.startH + dy);
				resizeState.element.style.width = w + 'px';
				resizeState.element.style.height = h + 'px';
				if (e.cancelable) e.preventDefault();
			}
		}

		function onEnd() {
			if (dragState) {
				dragState.element.classList.remove('dragging');
				dragState = null;
			}
			if (resizeState) {
				resizeState.element.classList.remove('resizing');
				resizeState = null;
			}
		}

		document.addEventListener('mousemove', onMove);
		document.addEventListener('mouseup', onEnd);
		document.addEventListener('touchmove', onMove, { passive: false });
		document.addEventListener('touchend', onEnd);

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') {
				windows.forEach((w, id) => {
					if (w.element.classList.contains('open') && !w.minimized) {
						closeWindow(id);
					}
				});
			}
		});
	}

	initWindowManager();
</script>
