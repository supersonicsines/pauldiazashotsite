---
interface Props {
	id: string;
	term: string;
	italic?: boolean;
}

const { id, term, italic = false } = Astro.props;
---

<span class:list={['anchor', { italic }]}>{term}</span><label
	for={`sn-${id}`}
	class="sidenote-marker"
></label><input type="checkbox" id={`sn-${id}`} class="sidenote-checkbox" /><span class="sidenote" role="note"><slot /></span>

<style>
	.anchor {
		text-decoration: underline;
		text-decoration-style: dotted;
		text-decoration-color: var(--color-rule);
		text-underline-offset: 3px;
	}

	.anchor.italic {
		font-style: italic;
	}

	.sidenote-marker {
		cursor: pointer;
		font-family: var(--font-sans);
		font-size: 0.7em;
		vertical-align: super;
		color: var(--color-bistre);
		font-weight: 500;
		padding: 0 2px;
		text-decoration: underline;
		text-decoration-style: dotted;
		text-decoration-color: var(--color-rule);
		text-underline-offset: 2px;
	}

	.sidenote-marker::before {
		content: "†";
	}

	.sidenote-checkbox {
		display: none;
	}

	.sidenote {
		font-family: var(--font-serif);
		font-size: 14px;
		line-height: 1.55;
		color: var(--color-ink);
		display: none;
		background: var(--color-sidenote-bg);
		padding: 10px 14px;
		margin: 8px 0;
		border-left: 2px solid var(--color-rule);
	}

	.sidenote-checkbox:checked ~ .sidenote {
		display: block;
	}

	.sidenote::before {
		content: "† ";
		font-family: var(--font-sans);
		font-size: 11px;
		font-weight: 500;
		vertical-align: super;
		color: var(--color-bistre);
		margin-right: 2px;
	}

</style>
